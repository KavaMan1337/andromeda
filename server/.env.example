# ── MongoDB ─────────────────────────────────────────────────────────────────
# Get free cluster at https://cloud.mongodb.com
# Format: mongodb://<username>:<password>@<shard1>:27017,<shard2>:27017,<shard3>:27017/?...
MONGODB_URI=mongodb://Andromeda:w6arCWeEbaTF439f@ac-o5ahzqh-shard-00-00.drsunyn.mongodb.net:27017,ac-o5ahzqh-shard-00-01.drsunyn.mongodb.net:27017,ac-o5ahzqh-shard-00-02.drsunyn.mongodb.net:27017/?appName=Andromeda&authSource=admin&serverSelectionTimeoutMS=15000&ssl=true&tls=true&tlsAllowInvalidCertificates=true

