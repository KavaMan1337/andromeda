# Andromeda Server — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Get free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/andromeda
MONGODB_URI=mongodb+srv://Andromeda:<password>@andromeda.drsunyn.mongodb.net/?appName=Andromeda

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random string, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── Resend (Email) ───────────────────────────────────────────────────────────
# Get free API key at https://resend.com — 100 emails/day free
# Use a verified domain OR add recipients to Resend dashboard for testing
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Andromeda <noreply@andromeda.gg>
# Set to true to see all emails in terminal instead of sending
EMAIL_DEMO_MODE=true